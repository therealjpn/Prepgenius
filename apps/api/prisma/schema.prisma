generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  passwordHash String?       @map("password_hash")
  fullName     String        @map("full_name")
  googleId     String?       @unique @map("google_id")
  avatarUrl    String?       @map("avatar_url")
  isPaid       Boolean       @default(false) @map("is_paid")
  isBanned     Boolean       @default(false) @map("is_banned")
  isAdmin      Boolean       @default(false) @map("is_admin")
  paymentRef   String?       @map("payment_ref")
  paidAt       DateTime?     @map("paid_at")
  referralCode String?       @unique @map("referral_code")
  referredById Int?          @map("referred_by_id")
  phone        String?
  network      String?       // MTN, Airtel, Glo, 9mobile
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  referredBy   User?         @relation("UserReferrals", fields: [referredById], references: [id])
  referrals    User[]        @relation("UserReferrals")

  examSessions ExamSession[]
  leaderboard  Leaderboard[]
  payments     Payment[]
  wallet       GeniuscoinWallet?
  referralRewards ReferralReward[] @relation("ReferrerRewards")
  referredRewards ReferralReward[] @relation("ReferredRewards")
  supportTickets  SupportTicket[]
  coinTransactions CoinTransaction[]
  payouts         Payout[]
  referralLeaderboard ReferralLeaderboard[]
  auditActions    AuditLog[]   @relation("AdminAuditActions")

  @@map("users")
}

model SupportTicket {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  subject    String
  message    String
  adminReply String?  @map("admin_reply")
  status     String   @default("open")
  createdAt  DateTime @default(now()) @map("created_at")
  resolvedAt DateTime? @map("resolved_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

model GeniuscoinWallet {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique @map("user_id")
  balance        Int      @default(0)
  totalEarned    Int      @default(0) @map("total_earned")
  totalRedeemed  Int      @default(0) @map("total_redeemed")
  lastRedeemDate DateTime? @map("last_redeem_date")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("geniuscoin_wallets")
}

model ReferralReward {
  id             Int      @id @default(autoincrement())
  referrerId     Int      @map("referrer_id")
  referredUserId Int      @map("referred_user_id")
  coinsAwarded   Int      @default(200) @map("coins_awarded")
  status         String   @default("pending")
  redeemableDate DateTime @map("redeemable_date")
  squadRef       String?  @map("squad_ref")
  referrerIp     String?  @map("referrer_ip")
  referredIp     String?  @map("referred_ip")
  flagged        Boolean  @default(false)
  flagReason     String?  @map("flag_reason")
  discountApplied Int     @default(0) @map("discount_applied")
  createdAt      DateTime @default(now()) @map("created_at")

  referrer     User @relation("ReferrerRewards", fields: [referrerId], references: [id])
  referredUser User @relation("ReferredRewards", fields: [referredUserId], references: [id])

  @@unique([referrerId, referredUserId])
  @@index([referrerId])
  @@map("referral_rewards")
}

model ExamSession {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  examType        String    @default("WAEC") @map("exam_type")
  subject         String
  year            String?
  totalQuestions  Int       @map("total_questions")
  correctAnswers  Int       @default(0) @map("correct_answers")
  scorePercentage Float     @default(0) @map("score_percentage")
  pointsEarned    Int       @default(0) @map("points_earned")
  timeTakenSeconds Int?     @map("time_taken_seconds")
  answersJson     String?   @map("answers_json")
  questionsJson   String?   @map("questions_json")
  startedAt       DateTime  @default(now()) @map("started_at")
  completed       Boolean   @default(false)
  createdAt       DateTime  @default(now()) @map("created_at")
  completedAt     DateTime? @map("completed_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("exam_sessions")
}

model Leaderboard {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  weekStart      String   @map("week_start")
  totalPoints    Int      @default(0) @map("total_points")
  totalCorrect   Int      @default(0) @map("total_correct")
  totalQuestions Int      @default(0) @map("total_questions")
  examsTaken     Int      @default(0) @map("exams_taken")
  accuracy       Float    @default(0)
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, weekStart])
  @@index([weekStart, totalPoints(sort: Desc)])
  @@map("leaderboard")
}

model Payment {
  id             Int       @id @default(autoincrement())
  userId         Int       @map("user_id")
  reference      String    @unique
  amount         Int
  currency       String    @default("NGN")
  status         String    @default("pending")
  provider       String    @default("squad")
  metadata       String?
  discountAmount Int       @default(0) @map("discount_amount")
  referralCode   String?   @map("referral_code")
  createdAt      DateTime  @default(now()) @map("created_at")
  verifiedAt     DateTime? @map("verified_at")

  user User @relation(fields: [userId], references: [id])

  @@index([reference])
  @@map("payments")
}

model CoinTransaction {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  amount         Int      // positive = credit, negative = debit
  type           String   // referral_credit, payout_debit, clawback, bonus, admin_adjust
  reason         String
  relatedRef     String?  @map("related_ref")
  adminActorId   Int?     @map("admin_actor_id")
  balanceBefore  Int      @map("balance_before")
  balanceAfter   Int      @map("balance_after")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@map("coin_transactions")
}

model Payout {
  id             Int       @id @default(autoincrement())
  userId         Int       @map("user_id")
  batchMonth     String    @map("batch_month")  // e.g. "2026-04"
  coins          Int
  amountNgn      Int       @map("amount_ngn")
  phone          String?
  network        String?
  status         String    @default("pending")  // pending, paid, rejected, awaiting_info
  adminActorId   Int?      @map("admin_actor_id")
  adminNote      String?   @map("admin_note")
  processedAt    DateTime? @map("processed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([batchMonth, status])
  @@map("payouts")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  adminId     Int      @map("admin_id")
  action      String
  targetType  String   @map("target_type")
  targetId    Int?     @map("target_id")
  details     String?  // JSON string
  createdAt   DateTime @default(now()) @map("created_at")

  admin User @relation("AdminAuditActions", fields: [adminId], references: [id])

  @@index([adminId])
  @@index([action])
  @@map("audit_logs")
}

model ReferralLeaderboard {
  id                  Int      @id @default(autoincrement())
  userId              Int      @map("user_id")
  month               String   // e.g. "2026-04"
  successfulReferrals Int      @default(0) @map("successful_referrals")
  bonusCoins          Int      @default(0) @map("bonus_coins")
  createdAt           DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, month])
  @@index([month, successfulReferrals(sort: Desc)])
  @@map("referral_leaderboard")
}
